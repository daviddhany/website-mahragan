# Server port
PORT=3000

# MongoDB connection
MONGODB_URI=mongodb://127.0.0.1:27017/school_activity_app

# Session secret
SESSION_SECRET=make-this-a-long-random-secret-at-least-32-characters

# Node environment
NODE_ENV=production

# Google Cloud Storage
GCLOUD_PROJECT_ID=mahragan-uploads

GCS_BUCKET_NAME=mahragan-uploads

# Google Cloud service account JSON (entire contents, all in one line)
GCLOUD_KEY_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/.../cert.pem"}